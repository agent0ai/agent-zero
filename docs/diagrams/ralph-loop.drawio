        <!-- Example Usage -->
        <mxCell id="example-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666" vertex="1" parent="1">
          <mxGeometry x="60" y="695" width="500" height="90" as="geometry" />
        </mxCell>
        <mxCell id="example-label" value="Example Usage:" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="70" y="700" width="100" height="20" as="geometry" />
        </mxCell>
        <mxCell id="example-code" value="{{ralph_loop(&#xa;  action=&quot;start_loop&quot;,&#xa;  name=&quot;Implement User Auth&quot;,&#xa;  prompt=&quot;Implement JWT auth with tests. Output &lt;promise&gt;ALL_TESTS_PASSING&lt;/promise&gt; when done.&quot;,&#xa;  completion_promise=&quot;ALL_TESTS_PASSING&quot;,&#xa;  max_iterations=50&#xa;)}}" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;fontFamily=Courier New" vertex="1" parent="1">
