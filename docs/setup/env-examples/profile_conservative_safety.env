# ------------------------------------------------------------
# Agent Zero profile: Conservative safety-first
# Empty values are placeholders and should be skipped by apply script.
# ------------------------------------------------------------

# Authentication (optional placeholders)
AUTH_LOGIN=
AUTH_PASSWORD=
ROOT_PASSWORD=

# API keys (placeholders)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
MISTRAL_API_KEY=
XAI_API_KEY=
VENICE_API_KEY=
MOONSHOT_API_KEY=
COMETAPI_API_KEY=
HUGGINGFACE_API_KEY=
OLLAMA_API_KEY=
LM_STUDIO_API_KEY=
EL11_API_KEY=
BRAVE_API_KEY=
TAVILY_API_KEY=
ZAI_API_KEY=
ZAI_CODING_API_KEY=
AZURE_API_KEY=
AZURE_API_BASE=
AZURE_API_VERSION=
BEDROCK_AWS_ACCESS_KEY_ID=
BEDROCK_AWS_SECRET_ACCESS_KEY=
BEDROCK_AWS_REGION_NAME=

# --- Monologue guardrails ---
A0_SET_agent_max_iterations=60
A0_SET_agent_max_runtime_seconds=600
A0_SET_agent_max_consecutive_misformats=3
A0_SET_agent_max_consecutive_repairable_errors=3

# --- Tool args controls ---
A0_SET_tool_args_max_chars=80000
A0_SET_tool_args_spill_threshold_chars=12000
A0_SET_tool_args_spill_dir=usr/tmp/tool_args
A0_SET_tool_args_autorewrite_enabled=true

# --- Code execution reliability ---
A0_SET_code_exec_first_output_timeout=20
A0_SET_code_exec_between_output_timeout=10
A0_SET_code_exec_max_exec_timeout=120
A0_SET_code_exec_dialog_timeout=5
A0_SET_code_exec_output_max_chars=500000
A0_SET_code_exec_auto_dump_large_output=true
A0_SET_code_exec_dump_dir=usr/tmp/code_exec
A0_SET_code_exec_prefer_python_file_write=true

# --- Subordinate limits ---
A0_SET_subordinate_max_depth=1
A0_SET_subordinate_max_calls_per_turn=2
A0_SET_subordinate_max_runtime_seconds=180

# --- Queue/backpressure ---
A0_SET_queue_max_items=40
A0_SET_queue_max_total_chars=150000
A0_SET_queue_drop_policy=reject
A0_SET_queue_send_all_max_items=10

# --- Memory load guardrails ---
A0_SET_memory_load_limit_max=20
A0_SET_memory_load_query_max_chars=8000
A0_SET_memory_load_response_max_chars=18000

# --- History compression ---
A0_SET_history_compression_target_ratio=0.75
A0_SET_history_current_topic_ratio=0.55
A0_SET_history_topic_ratio=0.30
A0_SET_history_bulk_ratio=0.15
A0_SET_history_attention_current_ratio=0.70
A0_SET_history_attention_past_ratio=0.0
A0_SET_history_compress_max_passes=8

# --- Runtime budgets ---
A0_SET_runtime_turn_budget_seconds=420
A0_SET_runtime_task_budget_seconds=900
A0_SET_runtime_subordinate_budget_seconds=180

# --- Model call kwargs ---
A0_SET_chat_model_kwargs={"max_tokens":8192}
A0_SET_litellm_global_kwargs={"timeout":120,"stream_timeout":120}

# --- Additional known A0_SET keys (set or empty) ---
A0_SET_chat_model_provider=
A0_SET_chat_model_name=
