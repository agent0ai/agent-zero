# ------------------------------------------------------------
# Agent Zero profile: Intentionally tight guard-trigger test
# Empty values are placeholders and should be skipped by apply script.
# ------------------------------------------------------------

# Authentication (optional placeholders)
AUTH_LOGIN=
AUTH_PASSWORD=
ROOT_PASSWORD=

# API keys (placeholders)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
MISTRAL_API_KEY=
XAI_API_KEY=
VENICE_API_KEY=
MOONSHOT_API_KEY=
COMETAPI_API_KEY=
HUGGINGFACE_API_KEY=
OLLAMA_API_KEY=
LM_STUDIO_API_KEY=
EL11_API_KEY=
BRAVE_API_KEY=
TAVILY_API_KEY=
ZAI_API_KEY=
ZAI_CODING_API_KEY=
AZURE_API_KEY=
AZURE_API_BASE=
AZURE_API_VERSION=
BEDROCK_AWS_ACCESS_KEY_ID=
BEDROCK_AWS_SECRET_ACCESS_KEY=
BEDROCK_AWS_REGION_NAME=

# --- Monologue guardrails (tight) ---
A0_SET_agent_max_iterations=6
A0_SET_agent_max_runtime_seconds=120
A0_SET_agent_max_consecutive_misformats=2
A0_SET_agent_max_consecutive_repairable_errors=2

# --- Tool args controls (tight) ---
A0_SET_tool_args_max_chars=2000
A0_SET_tool_args_spill_threshold_chars=400
A0_SET_tool_args_spill_dir=usr/tmp/tool_args
A0_SET_tool_args_autorewrite_enabled=true

# --- Code execution reliability (tight) ---
A0_SET_code_exec_first_output_timeout=3
A0_SET_code_exec_between_output_timeout=2
A0_SET_code_exec_max_exec_timeout=8
A0_SET_code_exec_dialog_timeout=3
A0_SET_code_exec_output_max_chars=2000
A0_SET_code_exec_auto_dump_large_output=true
A0_SET_code_exec_dump_dir=usr/tmp/code_exec
A0_SET_code_exec_prefer_python_file_write=true

# --- Subordinate limits (tight) ---
A0_SET_subordinate_max_depth=1
A0_SET_subordinate_max_calls_per_turn=1
A0_SET_subordinate_max_runtime_seconds=10

# --- Queue/backpressure (tight) ---
A0_SET_queue_max_items=3
A0_SET_queue_max_total_chars=500
A0_SET_queue_drop_policy=reject
A0_SET_queue_send_all_max_items=2

# --- Memory load guardrails (tight) ---
A0_SET_memory_load_limit_max=3
A0_SET_memory_load_query_max_chars=100
A0_SET_memory_load_response_max_chars=300

# --- History compression (aggressive) ---
A0_SET_history_compression_target_ratio=0.50
A0_SET_history_current_topic_ratio=0.50
A0_SET_history_topic_ratio=0.30
A0_SET_history_bulk_ratio=0.20
A0_SET_history_attention_current_ratio=0.65
A0_SET_history_attention_past_ratio=0.00
A0_SET_history_compress_max_passes=3

# --- Runtime budgets (tight) ---
A0_SET_runtime_turn_budget_seconds=60
A0_SET_runtime_task_budget_seconds=180
A0_SET_runtime_subordinate_budget_seconds=20

# --- Model call kwargs ---
A0_SET_chat_model_kwargs={"max_tokens":4096}
A0_SET_litellm_global_kwargs={"timeout":60,"stream_timeout":60}

# --- Additional known A0_SET keys (set or empty) ---
A0_SET_chat_model_provider=
A0_SET_chat_model_name=
A0_SET_chat_model_api_base=
A0_SET_chat_model_ctx_length=
A0_SET_chat_model_ctx_history=
