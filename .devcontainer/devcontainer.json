{
  "name": "Agent Zero Development",
  "build": {
    "dockerfile": "../DockerfileLocal",
    "context": ".."
  },
  "features": {
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.12"
    },
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    },
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.debugpy",
        "usernamehw.errorlens",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.testing.pytestEnabled": true,
        "python.testing.pytestArgs": ["tests"],
        "editor.formatOnSave": true
      }
    }
  },
  "forwardPorts": [5000, 80, 22, 9000, 9001, 9002],
  "postCreateCommand": "pip install -r requirements.txt && playwright install chromium",
  "remoteUser": "root",
  "mounts": [
    "source=${localWorkspaceFolder}/memory,target=/a0/memory,type=bind",
    "source=${localWorkspaceFolder}/knowledge,target=/a0/knowledge,type=bind",
    "source=${localWorkspaceFolder}/logs,target=/a0/logs,type=bind"
  ],
  "containerEnv": {
    "CODE_EXEC_SSH_ENABLED": "false",
    "PYTHONPATH": "/a0"
  }
}
