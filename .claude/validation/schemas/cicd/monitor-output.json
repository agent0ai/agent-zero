{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CICD Monitor Output Schema",
  "type": "object",
  "required": ["monitor_status"],
  "properties": {
    "monitor_status": {"type": "string", "enum": ["healthy", "issues", "down"]},
    "pipelines_monitored": {"type": "integer", "minimum": 0}
  }
}
