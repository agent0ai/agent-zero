{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://mahoosuc.dev/schemas/agent-os/tasks-output.json",
  "version": "1.0.0",
  "title": "Tasks Output Validation Schema",
  "description": "Validates output from /agent-os/create-tasks command",
  "type": "object",
  "required": ["files_created", "content_validation", "quality_metrics"],
  "properties": {
    "files_created": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "min_size", "required_sections"],
        "properties": {
          "path": {
            "type": "string",
            "pattern": "^agent-os/specs/[a-z0-9-]+/tasks\\.md$",
            "description": "Path to tasks.md file"
          },
          "min_size": {
            "type": "number",
            "minimum": 1500,
            "description": "Minimum file size in characters"
          },
          "required_sections": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "Phase 1: Backend Implementation",
                "Phase 2: Frontend Implementation",
                "Phase 3: Integration & Testing",
                "Phase 4: Deployment & Monitoring",
                "Testing Tasks",
                "Documentation Tasks"
              ]
            },
            "minItems": 4
          }
        }
      }
    },
    "content_validation": {
      "type": "object",
      "required": ["total_tasks", "testing_tasks", "documentation_tasks", "dependencies_defined"],
      "properties": {
        "total_tasks": {
          "type": "number",
          "minimum": 5,
          "description": "Minimum total number of tasks"
        },
        "testing_tasks": {
          "type": "number",
          "minimum": 2,
          "description": "Minimum number of testing tasks"
        },
        "documentation_tasks": {
          "type": "number",
          "minimum": 1,
          "description": "Minimum number of documentation tasks"
        },
        "dependencies_defined": {
          "type": "boolean",
          "description": "Whether task dependencies are clearly defined"
        },
        "acceptance_criteria_per_task": {
          "type": "boolean",
          "description": "Whether each task has acceptance criteria"
        },
        "time_estimates_provided": {
          "type": "boolean",
          "description": "Whether tasks have time estimates"
        },
        "references_spec": {
          "type": "boolean",
          "description": "Whether tasks reference spec.md sections"
        }
      }
    },
    "quality_metrics": {
      "type": "object",
      "required": ["task_granularity", "dependency_clarity", "testability"],
      "properties": {
        "task_granularity": {
          "$ref": "https://mahoosuc.dev/schemas/common/quality-score.json",
          "minimum": 0.85,
          "description": "How well tasks are broken down (not too large, not too small)"
        },
        "dependency_clarity": {
          "$ref": "https://mahoosuc.dev/schemas/common/quality-score.json",
          "minimum": 0.9,
          "description": "How clear task dependencies are"
        },
        "testability": {
          "$ref": "https://mahoosuc.dev/schemas/common/quality-score.json",
          "minimum": 0.9,
          "description": "How testable tasks are"
        },
        "overall_score": {
          "$ref": "https://mahoosuc.dev/schemas/common/quality-score.json",
          "minimum": 0.9
        }
      }
    }
  }
}
