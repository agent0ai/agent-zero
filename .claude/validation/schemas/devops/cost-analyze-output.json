{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Cost Analysis Output Schema",
  "description": "Validation schema for /devops/cost-analyze command output",
  "type": "object",
  "required": ["analysis_status", "total_cost", "cost_breakdown"],
  "properties": {
    "analysis_status": {
      "type": "string",
      "enum": ["completed", "failed"]
    },
    "total_cost": {
      "type": "number",
      "minimum": 0
    },
    "cost_breakdown": {
      "type": "object"
    }
  }
}
