{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Debug Output Schema",
  "description": "Validation schema for /devops/debug command output",
  "type": "object",
  "required": ["debug_status", "issues_found", "root_cause_identified"],
  "properties": {
    "debug_status": {
      "type": "string",
      "enum": ["resolved", "identified", "investigating"]
    },
    "issues_found": {
      "type": "integer",
      "minimum": 0
    },
    "root_cause_identified": {
      "type": "boolean"
    }
  }
}
