{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://mahoosuc.dev/schemas/design-os/section-spec-output.json",
  "version": "1.0.0",
  "title": "Section Spec Output Schema",
  "description": "Validates output from /design-os/shape-section command",
  "type": "object",
  "required": ["files_created", "content_validation", "quality_metrics"],
  "properties": {
    "files_created": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "min_size", "required_sections"],
        "properties": {
          "path": {
            "type": "string",
            "pattern": "^design-os/[a-z0-9-]+/sections/[a-z0-9-]+/spec\\.md$"
          },
          "min_size": {
            "type": "number",
            "minimum": 1000
          },
          "required_sections": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "Section Overview",
                "User Flows",
                "UI Patterns",
                "Data Requirements",
                "Interactions"
              ]
            },
            "minItems": 4
          }
        }
      }
    },
    "content_validation": {
      "type": "object",
      "properties": {
        "user_flows_defined": {
          "type": "number",
          "minimum": 1
        },
        "ui_patterns_defined": {
          "type": "number",
          "minimum": 2
        },
        "data_requirements_present": {
          "type": "boolean"
        },
        "interaction_patterns_defined": {
          "type": "boolean"
        }
      }
    },
    "quality_metrics": {
      "type": "object",
      "properties": {
        "clarity_score": {
          "$ref": "https://mahoosuc.dev/schemas/common/quality-score.json",
          "minimum": 0.9
        },
        "completeness_score": {
          "$ref": "https://mahoosuc.dev/schemas/common/quality-score.json",
          "minimum": 0.9
        },
        "overall_score": {
          "$ref": "https://mahoosuc.dev/schemas/common/quality-score.json",
          "minimum": 0.9
        }
      }
    }
  }
}
