{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://mahoosuc.dev/schemas/design-os/product-vision-output.json",
  "version": "1.0.0",
  "title": "Product Vision Output Schema",
  "description": "Validates output from /design-os/product-vision command",
  "type": "object",
  "required": ["files_created", "content_validation", "quality_metrics"],
  "properties": {
    "files_created": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "min_size", "required_sections"],
        "properties": {
          "path": {
            "type": "string",
            "pattern": "^design-os/[a-z0-9-]+/vision\\.md$"
          },
          "min_size": {
            "type": "number",
            "minimum": 1500
          },
          "required_sections": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "Product Overview",
                "Problem Statement",
                "Solution",
                "Target Users",
                "Key Features",
                "Success Metrics",
                "Competitive Landscape"
              ]
            },
            "minItems": 5
          }
        }
      }
    },
    "content_validation": {
      "type": "object",
      "properties": {
        "problem_statements": {
          "type": "number",
          "minimum": 3
        },
        "key_features": {
          "type": "number",
          "minimum": 5
        },
        "success_metrics": {
          "type": "number",
          "minimum": 3
        },
        "target_users_defined": {
          "type": "boolean"
        }
      }
    },
    "quality_metrics": {
      "type": "object",
      "properties": {
        "clarity_score": {
          "$ref": "https://mahoosuc.dev/schemas/common/quality-score.json",
          "minimum": 0.9
        },
        "completeness_score": {
          "$ref": "https://mahoosuc.dev/schemas/common/quality-score.json",
          "minimum": 0.9
        },
        "overall_score": {
          "$ref": "https://mahoosuc.dev/schemas/common/quality-score.json",
          "minimum": 0.9
        }
      }
    }
  }
}
