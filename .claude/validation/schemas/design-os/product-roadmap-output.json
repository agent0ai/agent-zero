{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://mahoosuc.dev/schemas/design-os/product-roadmap-output.json",
  "version": "1.0.0",
  "title": "Product Roadmap Output Schema",
  "description": "Validates output from /design-os/product-roadmap command",
  "type": "object",
  "required": ["files_created", "content_validation", "quality_metrics"],
  "properties": {
    "files_created": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "min_size", "required_sections"],
        "properties": {
          "path": {
            "type": "string",
            "pattern": "^design-os/[a-z0-9-]+/roadmap\\.md$"
          },
          "min_size": {
            "type": "number",
            "minimum": 1000
          },
          "required_sections": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "Roadmap Overview",
                "Buildable Sections",
                "Priority Order",
                "Dependencies",
                "Timeline Estimates"
              ]
            },
            "minItems": 4
          }
        }
      }
    },
    "content_validation": {
      "type": "object",
      "properties": {
        "buildable_sections": {
          "type": "number",
          "minimum": 3,
          "maximum": 8
        },
        "priority_order_defined": {
          "type": "boolean"
        },
        "dependencies_mapped": {
          "type": "boolean"
        },
        "timeline_estimates_present": {
          "type": "boolean"
        }
      }
    },
    "quality_metrics": {
      "type": "object",
      "properties": {
        "clarity_score": {
          "$ref": "https://mahoosuc.dev/schemas/common/quality-score.json",
          "minimum": 0.9
        },
        "completeness_score": {
          "$ref": "https://mahoosuc.dev/schemas/common/quality-score.json",
          "minimum": 0.9
        },
        "overall_score": {
          "$ref": "https://mahoosuc.dev/schemas/common/quality-score.json",
          "minimum": 0.9
        }
      }
    }
  }
}
