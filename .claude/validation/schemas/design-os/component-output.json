{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://mahoosuc.dev/schemas/design-os/component-output.json",
  "version": "1.0.0",
  "title": "Component Output Schema",
  "description": "Validates output from /design-os/design-screen command",
  "type": "object",
  "required": ["files_created", "content_validation", "quality_metrics"],
  "properties": {
    "files_created": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "min_size", "component_characteristics"],
        "properties": {
          "path": {
            "type": "string",
            "pattern": "^design-os/[a-z0-9-]+/sections/[a-z0-9-]+/components/.*\\.(tsx|jsx)$"
          },
          "min_size": {
            "type": "number",
            "minimum": 300
          },
          "component_characteristics": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "react_component",
                "typescript",
                "tailwind_css",
                "accessibility",
                "responsive"
              ]
            },
            "minItems": 4
          }
        }
      }
    },
    "content_validation": {
      "type": "object",
      "properties": {
        "react_typescript": {
          "type": "boolean"
        },
        "tailwind_css_used": {
          "type": "boolean"
        },
        "aria_attributes": {
          "type": "boolean"
        },
        "responsive_design": {
          "type": "boolean"
        },
        "sample_data_integrated": {
          "type": "boolean"
        }
      }
    },
    "quality_metrics": {
      "type": "object",
      "properties": {
        "code_quality_score": {
          "$ref": "https://mahoosuc.dev/schemas/common/quality-score.json",
          "minimum": 0.85
        },
        "accessibility_score": {
          "$ref": "https://mahoosuc.dev/schemas/common/quality-score.json",
          "minimum": 0.85
        },
        "design_quality_score": {
          "$ref": "https://mahoosuc.dev/schemas/common/quality-score.json",
          "minimum": 0.9
        },
        "overall_score": {
          "$ref": "https://mahoosuc.dev/schemas/common/quality-score.json",
          "minimum": 0.9
        }
      }
    }
  }
}
