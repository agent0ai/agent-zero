{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Dependency Check Output Schema",
  "type": "object",
  "required": ["check_status"],
  "properties": {
    "check_status": {"type": "string", "enum": ["passed", "failed", "warnings"]},
    "vulnerabilities_found": {"type": "integer", "minimum": 0}
  }
}
