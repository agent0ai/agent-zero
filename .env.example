# ============================================
# Agent Zero Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# Lines starting with # are comments

# ============================================
# MODEL CONFIGURATION
# ============================================
# Provider: openai, anthropic, google, azure, ollama, lm_studio, openrouter, groq, other
# CHAT_MODEL_PROVIDER=openai
# CHAT_MODEL_NAME=gpt-4o
# CHAT_MODEL_API_BASE=              # Leave empty for default. Set for Azure, Ollama, LM Studio
# CHAT_MODEL_CTX_LENGTH=128000      # Context window size in tokens
# CHAT_MODEL_VISION=true            # Enable vision capabilities

# Utility model (for summarization, extraction, etc.)
# UTIL_MODEL_PROVIDER=openai
# UTIL_MODEL_NAME=gpt-4o-mini
# UTIL_MODEL_API_BASE=
# UTIL_MODEL_CTX_LENGTH=128000

# Embedding model (for memory/knowledge)
# EMBED_MODEL_PROVIDER=openai
# EMBED_MODEL_NAME=text-embedding-3-small
# EMBED_MODEL_API_BASE=

# Browser model (for web browsing agent)
# BROWSER_MODEL_PROVIDER=openai
# BROWSER_MODEL_NAME=gpt-4o
# BROWSER_MODEL_VISION=true

# ============================================
# API KEYS
# ============================================
# Set the API keys for providers you use
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=...
# AZURE_API_KEY=...
# AZURE_API_BASE=https://YOUR_RESOURCE.openai.azure.com/
# AZURE_API_VERSION=2024-02-15-preview
# OPENROUTER_API_KEY=...
# GROQ_API_KEY=...

# ============================================
# ANTHROPIC ADVANCED FEATURES
# ============================================
# Prompt Caching (90% cost reduction, 85% latency improvement)
# ANTHROPIC_ENABLE_CACHING=true
# ANTHROPIC_CACHE_TTL_SECONDS=3600         # 1 hour for extended thinking, 300 for default

# Model Selection
# ANTHROPIC_OPUS_4_5_ENABLED=true
# ANTHROPIC_EFFORT_LEVEL=medium            # low, medium, high - controls token usage

# Batch API (50% cost discount for non-urgent tasks)
# ANTHROPIC_BATCH_ENABLED=true
# ANTHROPIC_BATCH_POLL_INTERVAL=300        # 5 minutes

# Advanced Features
# USE_NATIVE_ANTHROPIC_SDK=false           # Use LiteLLM by default, enable for advanced features
# ANTHROPIC_TOOL_SEARCH_ENABLED=true       # Dynamic tool discovery
# ANTHROPIC_PTC_ENABLED=true               # Programmatic Tool Calling (37% token reduction)

# For Ollama (local)
# OLLAMA_BASE_URL=http://localhost:11434

# For LM Studio (local)
# LM_STUDIO_BASE_URL=http://localhost:1234/v1

# ============================================
# WEB UI CONFIGURATION
# ============================================
WEB_UI_PORT=5000
# AUTH_LOGIN=admin
# AUTH_PASSWORD=                    # Leave empty to disable auth

# ============================================
# CODE EXECUTION (SSH/Docker)
# ============================================
# Enable SSH-based code execution to Docker container
CODE_EXEC_SSH_ENABLED=true
CODE_EXEC_SSH_ADDR=localhost
CODE_EXEC_SSH_PORT=55022
CODE_EXEC_SSH_USER=root
# CODE_EXEC_SSH_PASS=               # Usually empty for key-based auth

# ============================================
# REMOTE FUNCTION CALLING (RFC)
# ============================================
# Connect to external Docker runtime
# RFC_AUTO_DOCKER=true              # Auto-start Docker container
# RFC_URL=http://localhost:55080
# RFC_PASSWORD=
# RFC_PORT_HTTP=55080
# RFC_PORT_SSH=55022

# ============================================
# MEMORY & KNOWLEDGE
# ============================================
# MEMORY_RECALL_ENABLED=true
# MEMORY_RECALL_DELAYED=true        # Delay recall for better context
# MEMORY_MEMORIZE_ENABLED=true
# MEMORY_MEMORIZE_CONSOLIDATION=true

# Agent profile to use (folder name in /agents/)
# AGENT_PROFILE=digital-clone
# AGENT_MEMORY_SUBDIR=digital-clone # Subdirectory for memory isolation
# AGENT_KNOWLEDGE_SUBDIR=digital-clone # Subdirectory for knowledge base

# ============================================
# MCP (MODEL CONTEXT PROTOCOL)
# ============================================
# MCP_SERVERS={}                    # JSON config or leave for mcp_config_claude.json
# MCP_CLIENT_INIT_TIMEOUT=30
# MCP_CLIENT_TOOL_TIMEOUT=60
# MCP_SERVER_ENABLED=false          # Enable Agent Zero as MCP server
# MCP_SERVER_TOKEN=                 # Token for MCP server auth

# ============================================
# AGENT-TO-AGENT COMMUNICATION
# ============================================
# A2A_SERVER_ENABLED=false

# ============================================
# SPEECH (STT/TTS)
# ============================================
# STT_MODEL_SIZE=base               # tiny, base, small, medium, large
# STT_LANGUAGE=en
# STT_SILENCE_THRESHOLD=0.02
# STT_SILENCE_DURATION=500
# STT_WAITING_TIMEOUT=5000
# TTS_KOKORO=true                   # Use Kokoro TTS

# ============================================
# GMAIL INTEGRATION
# ============================================
# Requires OAuth setup - see docs/gmail-setup.md
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=

# ============================================
# COWORK MODE
# ============================================
# COWORK_ENABLED=false
# COWORK_REQUIRE_APPROVALS=true
# COWORK_ALLOWED_PATHS=/home/user/projects

# ============================================
# OBSERVABILITY
# ============================================
# OBSERVABILITY_PROVIDER=           # langsmith, langfuse, or empty
# OBSERVABILITY_AUTO_STORE=false

# LangSmith
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=agent-zero
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Langfuse
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com

# ============================================
# TELEMETRY
# ============================================
# TELEMETRY_ENABLED=false
# TELEMETRY_MAX_EVENTS=1000

# ============================================
# DEVELOPMENT
# ============================================
# UPDATE_CHECK_ENABLED=true
# LITELLM_LOG=ERROR                 # ERROR, WARNING, INFO, DEBUG

# ============================================
# TELEGRAM DELIVERY
# ============================================
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
