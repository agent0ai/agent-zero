        <mxCell id="step8" value="8. Agent retries&#xa;(approved)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d4edda;strokeColor=#28a745" vertex="1" parent="1">
          <mxGeometry x="950" y="660" width="100" height="60" as="geometry" />
