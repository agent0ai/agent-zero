  <diagram id="cowork-system" name="Cowork System - Collaborative Approval Framework">
    <mxGraphModel dx="1434" dy="780" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="850" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="Cowork System - Collaborative Approval Framework" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=24;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="250" y="20" width="600" height="40" as="geometry" />
        </mxCell>

        <!-- Overview Section -->
        <mxCell id="overview-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;opacity=50" vertex="1" parent="1">
          <mxGeometry x="40" y="70" width="1020" height="60" as="geometry" />
        </mxCell>
        <mxCell id="overview" value="Purpose: The Cowork system provides a human-in-the-loop approval mechanism for agent tool executions. When tools operate on files/folders within designated 'cowork folders', they require explicit user approval before execution." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="50" y="75" width="1000" height="50" as="geometry" />
        </mxCell>

        <!-- Core Components -->
        <mxCell id="core-layer" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;opacity=50" vertex="1" parent="1">
          <mxGeometry x="40" y="150" width="500" height="180" as="geometry" />
        </mxCell>
        <mxCell id="core-label" value="Core Components (python/helpers/cowork.py)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="50" y="155" width="350" height="20" as="geometry" />
        </mxCell>

        <mxCell id="fingerprinting" value="Fingerprinting&#xa;───────────────────&#xa;• build_fingerprint()&#xa;• SHA256(tool_name + sorted_args)&#xa;• Deterministic hash for &#xa;  approval matching" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b0e3e6;strokeColor=#0e8088;align=left;spacingLeft=5" vertex="1" parent="1">
          <mxGeometry x="60" y="185" width="180" height="100" as="geometry" />
        </mxCell>
        <mxCell id="path-extraction" value="Path Extraction&#xa;───────────────────&#xa;• extract_paths(tool_args)&#xa;• PATH_KEYS: path, files,&#xa;  directory, folder, etc.&#xa;• Resolve env variables" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b0e3e6;strokeColor=#0e8088;align=left;spacingLeft=5" vertex="1" parent="1">
          <mxGeometry x="260" y="185" width="150" height="100" as="geometry" />
        </mxCell>
        <mxCell id="approval-check" value="Approval Check&#xa;───────────────────&#xa;• check_approval()&#xa;• is_in_cowork_folder()&#xa;• needs_approval()&#xa;• Hierarchical paths" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b0e3e6;strokeColor=#0e8088;align=left;spacingLeft=5" vertex="1" parent="1">
          <mxGeometry x="425" y="185" width="140" height="100" as="geometry" />
        </mxCell>
        <mxCell id="summarize" value="Arg Summarization&#xa;• summarize_tool_args()&#xa;• Truncate long paths&#xa;• Human-readable display" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacingLeft=5" vertex="1" parent="1">
          <mxGeometry x="60" y="295" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- API Endpoints -->
        <mxCell id="api-layer" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;opacity=50" vertex="1" parent="1">
          <mxGeometry x="560" y="150" width="500" height="180" as="geometry" />
        </mxCell>
        <mxCell id="api-label" value="API Endpoints (python/api/cowork_*)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="570" y="155" width="300" height="20" as="geometry" />
        </mxCell>

        <mxCell id="approvals-list" value="cowork_approvals_list.py&#xa;─────────────────────&#xa;GET /cowork_approvals_list&#xa;&#xa;Returns:&#xa;• Pending approvals queue&#xa;• Tool name, summarized args&#xa;• Agent number&#xa;• Timestamps" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;spacingLeft=5" vertex="1" parent="1">
          <mxGeometry x="580" y="185" width="180" height="130" as="geometry" />
        </mxCell>
        <mxCell id="approvals-update" value="cowork_approvals_update.py&#xa;─────────────────────&#xa;POST /cowork_approvals_update&#xa;&#xa;Body: { id, action }&#xa;Actions:&#xa;• approve&#xa;• reject&#xa;• approve_all" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;spacingLeft=5" vertex="1" parent="1">
          <mxGeometry x="780" y="185" width="170" height="130" as="geometry" />
        </mxCell>
        <mxCell id="folders-apis" value="cowork_folders_get/set.py&#xa;─────────────────────&#xa;GET /cowork_folders_get&#xa;POST /cowork_folders_set&#xa;&#xa;• List protected folders&#xa;• Add/remove folders&#xa;• Per-context config" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;spacingLeft=5" vertex="1" parent="1">
          <mxGeometry x="970" y="185" width="160" height="130" as="geometry" />
        </mxCell>

        <!-- Extension Hook -->
        <mxCell id="extension-layer" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;opacity=50" vertex="1" parent="1">
          <mxGeometry x="40" y="350" width="500" height="100" as="geometry" />
        </mxCell>
        <mxCell id="ext-label" value="Extension Hook (python/extensions/tool_execute_before/)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="50" y="355" width="400" height="20" as="geometry" />
        </mxCell>

        <mxCell id="cowork-ext" value="_20_cowork_approvals.py&#xa;────────────────────────────────────────────&#xa;• Intercepts tool execution BEFORE it runs&#xa;• Checks if tool paths are in cowork folders&#xa;• If yes: creates pending approval &amp; blocks execution&#xa;• If no: allows tool to proceed normally&#xa;• Returns Response with break_loop=True if blocked" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacingLeft=5" vertex="1" parent="1">
          <mxGeometry x="60" y="380" width="460" height="60" as="geometry" />
        </mxCell>

        <!-- Data Structure -->
        <mxCell id="data-layer" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;opacity=50" vertex="1" parent="1">
          <mxGeometry x="560" y="350" width="500" height="200" as="geometry" />
        </mxCell>
        <mxCell id="data-label" value="Approval Data Structure (stored in AgentContext.data['cowork_approvals'])" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="570" y="355" width="480" height="20" as="geometry" />
        </mxCell>

        <mxCell id="approval-schema" value="{&#xa;  &quot;id&quot;: &quot;uuid-v4&quot;,&#xa;  &quot;fingerprint&quot;: &quot;sha256(tool+args)&quot;,&#xa;  &quot;tool_name&quot;: &quot;code_execution_tool&quot;,&#xa;  &quot;tool_args&quot;: {&#xa;    &quot;path&quot;: &quot;/cowork/project/...&quot;,&#xa;    &quot;content&quot;: &quot;[truncated...]&quot;&#xa;  },&#xa;  &quot;status&quot;: &quot;pending|approved|rejected&quot;,&#xa;  &quot;agent_number&quot;: 0,&#xa;  &quot;inherit&quot;: false,&#xa;  &quot;created_at&quot;: &quot;ISO8601&quot;,&#xa;  &quot;resolved_at&quot;: &quot;ISO8601&quot;,&#xa;  &quot;consumed&quot;: false,&#xa;  &quot;consumed_at&quot;: &quot;ISO8601&quot;&#xa;}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d4edda;strokeColor=#28a745;align=left;spacingLeft=10;fontFamily=Courier New" vertex="1" parent="1">
          <mxGeometry x="580" y="385" width="250" height="155" as="geometry" />
        </mxCell>

        <mxCell id="status-flow" value="Status Lifecycle:&#xa;&#xa;1. pending → User sees in queue&#xa;2. approved → Tool can execute&#xa;3. rejected → Tool blocked&#xa;4. consumed → Approval used&#xa;&#xa;Inheritance:&#xa;• inherit=true: approval applies&#xa;  to all sub-agents" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;spacingLeft=5" vertex="1" parent="1">
          <mxGeometry x="850" y="385" width="190" height="155" as="geometry" />
        </mxCell>

