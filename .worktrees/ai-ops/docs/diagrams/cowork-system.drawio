        <!-- Flow Steps -->
        <mxCell id="step1" value="1. Agent calls&#xa;tool with path&#xa;argument" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6" vertex="1" parent="1">
          <mxGeometry x="60" y="660" width="100" height="60" as="geometry" />
        </mxCell>
        <mxCell id="step2" value="2. Extension&#xa;intercepts&#xa;(before exec)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6" vertex="1" parent="1">
          <mxGeometry x="190" y="660" width="100" height="60" as="geometry" />
        </mxCell>
        <mxCell id="step3" value="3. Check if&#xa;path in cowork&#xa;folders" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656" vertex="1" parent="1">
          <mxGeometry x="320" y="650" width="100" height="80" as="geometry" />
        </mxCell>
        <mxCell id="step4a" value="NO:&#xa;Execute&#xa;normally" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d4edda;strokeColor=#28a745" vertex="1" parent="1">
          <mxGeometry x="320" y="750" width="100" height="40" as="geometry" />
        </mxCell>
        <mxCell id="step4b" value="4. YES:&#xa;Create pending&#xa;approval" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450" vertex="1" parent="1">
          <mxGeometry x="450" y="660" width="100" height="60" as="geometry" />
        </mxCell>
        <mxCell id="step5" value="5. Block tool&#xa;execution&#xa;(break_loop)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450" vertex="1" parent="1">
          <mxGeometry x="580" y="660" width="100" height="60" as="geometry" />
        </mxCell>
        <mxCell id="step6" value="6. User sees&#xa;approval in&#xa;UI queue" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf" vertex="1" parent="1">
          <mxGeometry x="710" y="660" width="100" height="60" as="geometry" />
        </mxCell>
        <mxCell id="step7" value="7. User&#xa;approves/&#xa;rejects" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656" vertex="1" parent="1">
          <mxGeometry x="840" y="650" width="80" height="80" as="geometry" />
