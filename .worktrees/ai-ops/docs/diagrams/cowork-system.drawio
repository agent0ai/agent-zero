        <mxCell id="cowork-store" value="cowork-store.js&#xa;──────────────────────&#xa;Alpine.js state:&#xa;• approvals: []&#xa;• folders: []&#xa;• loadApprovals()&#xa;• approve/reject(id)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b0e3e6;strokeColor=#0e8088;align=left;spacingLeft=5" vertex="1" parent="1">
