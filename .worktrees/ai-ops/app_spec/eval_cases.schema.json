{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "app_spec/eval_cases.schema.json",
  "title": "Eval Cases Spec",
  "type": "object",
  "properties": {
    "$schema": {"type": "string"},
    "eval_cases": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "title": {"type": "string"},
          "use_case_id": {"type": "string"},
          "user_story_id": {"type": "string"},
          "prompt": {"type": "string"},
          "expected_tools": {"type": "array", "items": {"type": "string"}},
          "expected_keywords": {"type": "array", "items": {"type": "string"}},
          "notes": {"type": "string"}
        },
        "required": ["id", "title", "prompt"],
        "additionalProperties": false
      }
    }
  },
  "required": ["eval_cases"],
  "additionalProperties": false
}
