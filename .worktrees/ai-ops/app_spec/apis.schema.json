{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "app_spec/apis.schema.json",
  "title": "APIs Spec",
  "type": "object",
  "properties": {
    "$schema": {"type": "string"},
    "apis": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "path": {"type": "string"},
          "method": {"type": "string"},
          "purpose": {"type": "string"},
          "outputs": {"type": "array", "items": {"type": "string"}}
        },
        "required": ["path", "method", "purpose"],
        "additionalProperties": false
      }
    }
  },
  "required": ["apis"],
  "additionalProperties": false
}
